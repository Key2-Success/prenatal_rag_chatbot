# OpenAI — required.
# Used for: embeddings (text-embedding-3-small at ingest + query time),
# the answer LLM (gpt-4.1-nano), the classifier LLM, and the OpenAI
# embeddings inside the RAGAS judge for ResponseRelevancy.
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic — required ONLY for `python -m eval.ragas_eval`.
# RAGAS uses an LLM-as-judge to score answer quality. Best practice is a
# cross-vendor judge (Claude judging GPT) to avoid same-family bias —
# see .claude/skills/ragas/references/pitfalls.md #2. The rest of the app
# runs fine without this key.
ANTHROPIC_API_KEY=

# LlamaCloud — required ONLY for `python -m scripts.ingest`.
# LlamaParse (LlamaIndex Cloud) parses PDFs into markdown — proper tables,
# multi-column linearisation, figures with captions, OCR fallback for scans.
# Replaces pypdf, which flattened nutrition tables and figures into unusable
# soup. The runtime app reads from Pinecone and doesn't need this key.
# Sign up at https://cloud.llamaindex.ai (free tier = 1000 pages/day, more
# than enough for this project's corpus).
LLAMA_CLOUD_API_KEY=

# Pinecone — required.
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=poshan-saathi

# App
APP_ENV=development  # development | production

# Langfuse (observability — optional)
# Leave blank to disable. With keys set, the OpenAI client is auto-wrapped
# and every /chat call shows up as a trace tree (classifier → retrieve → answer)
# at https://cloud.langfuse.com (or your self-hosted host).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
